# ─── Telephony mode ─────────────────────────────────────────
# auto   = Retell if RETELL_* set, else GSM/Pipecat pipeline
# retell = Port/Twilio → Retell (מספר בענן)
# gsm    = SIM בקופסה → Pipecat (מספר הסים שלך)
TELEPHONY_MODE=auto

# ─── Retell (מסלול 1 — Port/Twilio) ────────────────────────
RETELL_API_KEY=
RETELL_AGENT_ID=
RETELL_FROM_NUMBER=+972...
RETELL_POLL_INTERVAL_MS=3000
RETELL_MAX_POLL_MS=600000

# ─── GSM / Pipecat pipeline (מסלול 2 — הסים שלך) ───────────
PIPELINE_URL=http://127.0.0.1:8090
PIPELINE_MODE=sim                      # sim | asterisk
PIPELINE_PORT=8090
PIPELINE_POLL_INTERVAL_MS=3000
PIPELINE_MAX_POLL_MS=600000

# Pipecat bridge (Stasis answer → agent)
# none | bridge_sim | external_media
PIPECAT_TRANSPORT=none
PIPECAT_EXTERNAL_HOST=127.0.0.1:4000
PIPECAT_MEDIA_FORMAT=slin16
# PIPECAT_AGENT_CMD=python3 agent.py --context /tmp/pelozen-calls/<id>.json

# Asterisk ARI (כש-PIPELINE_MODE=asterisk + קופסת GSM)
ASTERISK_ARI_URL=http://127.0.0.1:8088/ari
ASTERISK_ARI_USER=pelozen
ASTERISK_ARI_PASSWORD=
ASTERISK_STASIS_APP=pelozen
GSM_GATEWAY_ENDPOINT=gsm               # PJSIP endpoint name in Asterisk

# Voice keys (Pipecat — מסלול GSM)
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
LLM_PROVIDER=gemini

# Legacy SIP gateway direct (OpenVox registers to Asterisk)
SIP_GATEWAY_HOST=
SIP_USERNAME=
SIP_PASSWORD=
CALLER_ID=+972501234567                # המספר על הסים / caller ID

# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── pelozen scraper ────────────────────────────────────────
PELOZEN_USERNAME=
PELOZEN_PASSWORD=

# ─── Orchestrator + web ─────────────────────────────────────
ORCHESTRATOR_PORT=8080
ORCHESTRATOR_URL=http://localhost:8080
NEXT_PUBLIC_ORCHESTRATOR_URL=http://localhost:8080
PHONE_HASH_SECRET=
