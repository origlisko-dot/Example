# ─── Supabase ───────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=        # orchestrator only — NEVER in the web client

# ─── Voice pipeline (Pipecat) ───────────────────────────────
DEEPGRAM_API_KEY=                 # STT, Hebrew (nova-3)
CARTESIA_API_KEY=                 # TTS, cloned voice
CARTESIA_VOICE_ID=                # the owner's cloned-voice id
# LLM — pick one provider:
GOOGLE_API_KEY=                   # Gemini Flash (default)
ANTHROPIC_API_KEY=                # Claude Haiku (alternative)
LLM_PROVIDER=gemini               # gemini | anthropic

# ─── Telephony (SIP) ────────────────────────────────────────
# GSM gateway registered to Asterisk/FreeSWITCH, or a VoIP SIP trunk fallback.
SIP_GATEWAY_HOST=
SIP_USERNAME=
SIP_PASSWORD=
CALLER_ID=+972545456212           # the owner's SIM number

# ─── pelozen lead source (scraper, phase 4) ─────────────────
PELOZEN_BASE_URL=https://m.pelozen.co.il
PELOZEN_USERNAME=
PELOZEN_PASSWORD=                 # encrypted at rest in production

# ─── Orchestrator ───────────────────────────────────────────
ORCHESTRATOR_PORT=8080
PHONE_HASH_SECRET=                # HMAC key for phone_hash dedup/suppression lookups
