  "dependencies": {
    "@pelozen/shared": "*",
    "@supabase/supabase-js": "^2.45.0",
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "@types/node": "^20.16.0"
  }
}
