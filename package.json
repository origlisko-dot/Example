{
  "name": "pelozen-caller",
  "version": "0.1.0",
  "private": true,
  "description": "Hebrew AI outbound qualification caller — voice bot in the owner's cloned voice",
  "workspaces": [
    "shared",
    "orchestrator",
    "web"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:orchestrator": "npm run dev --workspace orchestrator",
    "dev:web": "npm run dev --workspace web"
  },
  "engines": {
    "node": ">=20"
  }
}
