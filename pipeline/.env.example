# Voice pipeline secrets (separate from the Node orchestrator).
DEEPGRAM_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=          # the owner's cloned-voice id
LLM_PROVIDER=gemini         # gemini | anthropic
GOOGLE_API_KEY=
